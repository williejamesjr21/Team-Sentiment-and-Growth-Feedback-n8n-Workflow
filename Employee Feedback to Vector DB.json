    {
      "parameters": {
        "mode": "runOnceForEachItem",
        "jsCode": "let aiOutput = $input.item.json.output;\n\n// Remove markdown code blocks if present\naiOutput = aiOutput.replace(/```json\\s*/g, \"\").replace(/```\\s*$/g, \"\").trim();\n\ntry {\n  let feedbackRecord = JSON.parse(aiOutput);\n  \n  // If it's an array with one item, extract it\n  if (Array.isArray(feedbackRecord) && feedbackRecord.length === 1) {\n    feedbackRecord = feedbackRecord[0];\n  }\n  \n  // Return as n8n item\n  return { json: feedbackRecord };\n  \n} catch (error) {\n  return { json: { error: \"Failed to parse JSON: \" + error.message, raw_output: aiOutput } };\n}"
      },
